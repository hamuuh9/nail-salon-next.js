# Environment Variables for Nail Salon Next.js App

# Site URL (used for absolute URLs in emails, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: Database connection string (if using external database)
# DATABASE_URL=your_database_connection_string

# Optional: Email service credentials (for sending notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=your-google-analytics-id